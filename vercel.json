{
  "buildCommand": "cd family-trip-app && npm install && npm run build",
  "outputDirectory": "family-trip-app/dist",
  "installCommand": "echo 'skip'",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
